# =========================================
# Mecoria OS
# Git Ignore
# =========================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.venv/
venv/
env/

# Environment
.env
.env.*
!.env.example

# Logs
*.log
logs/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Python Cache
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Build
dist/
build/
*.egg-info/

# Temporary Files
*.tmp
*.temp

# Secrets
secrets/
credentials.json
*.pem
*.key

# Node
node_modules/

# Docker
*.pid

# Misc
.cache/
exports/

# Local media assets - do not commit
assets/stock/
assets/raw/
assets/video/
assets/audio/

# Large media files - do not commit
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.wav
*.mp3
*.aac
*.m4a

# Agent runtime outputs - do not commit
agents/*/output/
