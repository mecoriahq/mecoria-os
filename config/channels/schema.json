{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mecoria Media Channel Config",
  "type": "object",
  "required": [
    "schema_version",
    "channel",
    "display_name",
    "status",
    "production_enabled",
    "language",
    "timezone",
    "platforms",
    "content",
    "pipeline",
    "integrations",
    "youtube",
    "analytics",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "channel": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planning",
        "active",
        "paused",
        "archived"
      ]
    },
    "production_enabled": {
      "type": "boolean"
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "timezone": {
      "type": "string",
      "minLength": 3
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "content": {
      "type": "object",
      "required": [
        "niche",
        "format",
        "editorial_standard",
        "thumbnail_standard",
        "publishing_cadence_days"
      ],
      "properties": {
        "niche": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "editorial_standard": {
          "type": "string"
        },
        "thumbnail_standard": {
          "type": "string"
        },
        "publishing_cadence_days": {
          "type": "integer",
          "minimum": 1
        },
        "core_promise": {
          "type": "string"
        },
        "content_pillars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "pipeline": {
      "type": "object",
      "required": [
        "runner",
        "auto_resume",
        "auto_create_next_video",
        "topic_approval_required",
        "storyblocks_download_required",
        "founder_final_review_required",
        "automatic_public_release"
      ],
      "properties": {
        "runner": {
          "type": "string"
        },
        "auto_resume": {
          "type": "boolean"
        },
        "auto_create_next_video": {
          "type": "boolean"
        },
        "topic_approval_required": {
          "type": "boolean"
        },
        "storyblocks_download_required": {
          "type": "boolean"
        },
        "founder_final_review_required": {
          "type": "boolean"
        },
        "automatic_public_release": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "integrations": {
      "type": "object",
      "required": [
        "notion_sync",
        "youtube_analytics",
        "google_drive",
        "n8n"
      ],
      "properties": {
        "notion_sync": {
          "type": "boolean"
        },
        "youtube_analytics": {
          "type": "boolean"
        },
        "google_drive": {
          "type": "boolean"
        },
        "n8n": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "youtube": {
      "type": "object",
      "required": [
        "handle",
        "latest_public_video_id",
        "public_video_count"
      ],
      "properties": {
        "handle": {
          "type": [
            "string",
            "null"
          ]
        },
        "latest_public_video_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "public_video_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "analytics": {
      "type": "object",
      "required": [
        "checkpoints_hours",
        "next_action"
      ],
      "properties": {
        "checkpoints_hours": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "next_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": [
        "allow_cross_channel_asset_reuse",
        "allow_cross_channel_content_reuse",
        "require_explicit_execute_flag"
      ],
      "properties": {
        "allow_cross_channel_asset_reuse": {
          "type": "boolean"
        },
        "allow_cross_channel_content_reuse": {
          "type": "boolean"
        },
        "require_explicit_execute_flag": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "brand": {
      "type": "object",
      "required": [
        "domain",
        "workspace_email",
        "youtube_channel_created",
        "handle_reserved"
      ],
      "properties": {
        "domain": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspace_email": {
          "type": [
            "string",
            "null"
          ]
        },
        "youtube_channel_created": {
          "type": "boolean"
        },
        "handle_reserved": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
