{
  "channel": "hiddenova",
  "version": "1.0",
  "status": "active",
  "decision": "thumbnail_text_overlay_standard_enabled",
  "thumbnail_standard": {
    "platform": "youtube",
    "size": "1280x720",
    "aspect_ratio": "16:9",
    "text_overlay_required": true,
    "text_language": "english",
    "primary_goal": "increase click-through rate with short, clear, high-contrast thumbnail text",
    "text_rules": {
      "min_words": 1,
      "max_words": 4,
      "preferred_word_count": 2,
      "style": "short_punchy_curiosity_driven",
      "case_preference": "all_caps_or_strong_title_case",
      "font_weight": "bold",
      "readability": "high",
      "mobile_readability_required": true,
      "contrast_required": true
    },
    "visual_rules": {
      "keep_main_subject_clear": true,
      "do_not_cover_key_subject": true,
      "prefer_negative_space_for_text": true,
      "thumbnail_should_work_even_without_text": true,
      "text_should_support_not_replace_visual": true
    },
    "content_rules": {
      "must_create_curiosity": true,
      "must_match_video_topic": true,
      "must_not_repeat_full_video_title": true,
      "must_not_be_generic": true
    },
    "approved_patterns": [
      "WHERE RETURNS GO",
      "HIDDEN SYSTEM",
      "INSIDE RETURNS",
      "THE RETURN LOOP",
      "BEHIND RETURNS"
    ],
    "forbidden_patterns": [
      "long sentences",
      "tiny text",
      "low contrast text",
      "too many words",
      "text covering the core object",
      "full title copy on thumbnail"
    ],
    "notes": [
      "Hiddenova thumbnails should include short, effective text for better YouTube CTR.",
      "Text should be visually strong but minimal.",
      "Default rule: every thumbnail concept should propose at least 3 short text options.",
      "Final selected thumbnail should keep clean cinematic style."
    ]
  }
}
