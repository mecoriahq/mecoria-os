{
  "channel": "hiddenova",
  "version": "3.0",
  "status": "active",
  "decision": "hiddenova_thumbnail_system_v3_active",
  "thumbnail_standard": {
    "platform": "youtube",
    "size": "1280x720",
    "aspect_ratio": "16:9",
    "gold_reference": "config/media/reference_assets/hiddenova_cinematic_v2_gold.png",
    "layout_signature": "oversized_headline_left__dominant_subject_right",
    "primary_goal": "Generate three meaningfully different concepts, reject average work, and select the strongest mobile-first cinematic thumbnail.",
    "text_rules": {
      "min_words": 2,
      "max_words": 4,
      "preferred_word_count": 3,
      "case": "ALL_CAPS",
      "font_style": "Impact-style bold condensed sans",
      "placement": "left",
      "stacking": "2_or_3_lines",
      "primary_color": "white",
      "highlight_color": "yellow",
      "highlight_rule": "strongest final line",
      "stroke": "thick black",
      "shadow": "deep black",
      "mobile_readability_required": true
    },
    "visual_rules": {
      "single_dominant_subject": true,
      "subject_position": "right_or_center_right",
      "dark_cinematic_background": true,
      "high_contrast": true,
      "bright_focal_glow": true,
      "clean_negative_space_left": true,
      "series_style_must_match_gold_reference": true,
      "subject_must_change_by_topic": true
    },
    "approved_patterns": [
      "TWO SECOND VERDICT",
      "WHEN CABLES SNAP",
      "WHO REALLY DECIDES",
      "THE HIDDEN NETWORK",
      "SECONDS FROM FAILURE"
    ],
    "forbidden_patterns": [
      "one-word headline",
      "more than four words",
      "small headline",
      "headline on the right",
      "centered headline",
      "all-white text",
      "weak subject",
      "multiple competing subjects",
      "flat lighting",
      "generic stock poster",
      "full video title copy"
    ],
    "non_negotiables": [
      "oversized uppercase headline",
      "white and yellow two-color text",
      "headline on the left",
      "dominant subject on the right",
      "thick black outline and shadow",
      "dark high-contrast cinematic background",
      "one clear idea",
      "premium documentary look",
      "three distinct concepts per video",
      "actual rendered-image vision QA",
      "automatic weak-candidate rejection",
      "two finalist paths recorded",
      "highest approved score selected"
    ],
    "concept_system": {
      "candidate_count": 3,
      "finalist_count": 2,
      "concept_types": [
        "scale_and_consequence",
        "failure_or_risk",
        "hidden_mechanism"
      ],
      "vision_qa_required": true,
      "minimum_final_score": 85,
      "selection_policy": "highest_scoring_approved_candidate"
    }
  }
}