      "The subject must be a real company, founder, public figure, institution, empire, scandal, or mystery with strong public documentation.",
      "The story must have a clear turning point, conflict, rise, fall, power mechanism, or unresolved question.",
      "Prefer globally recognizable subjects with evergreen search demand and strong visual archives.",
      "Reject topics that depend mainly on gossip, private-life speculation, or unsupported conspiracy."
    ],
    "forbidden_angles": [
      "fictional biography",
      "celebrity gossip without business or historical significance",
      "unsupported criminal accusation",
      "private-person investigation",
      "medical diagnosis",
      "political persuasion",
      "generic net-worth listicle"
    ]
  },
  "script": {
