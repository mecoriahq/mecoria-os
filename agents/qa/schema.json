{
  "type": "object",
  "required": [
    "agent",
    "version",
    "channel",
    "status",
    "overall_score",
    "checks",
    "issues",
    "recommendations",
    "metadata"
  ],
  "properties": {
    "agent": {
      "type": "string",
      "const": "qa"
    },
    "version": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "overall_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "checks": {
      "type": "object",
      "required": [
        "script_quality",
        "hook_strength",
        "hook_intro_distinctness",
        "narrative_spine",
        "specificity",
        "repetition_risk",
        "seo_alignment",
        "title_quality",
        "title_thumbnail_synergy",
        "hiddenova_brand_intro",
        "standard_cta",
        "description_quality",
        "tags_quality",
        "thumbnail_text_quality"
      ],
      "properties": {
        "script_quality": {
          "$ref": "#/$defs/check_result"
        },
        "hook_strength": {
          "$ref": "#/$defs/check_result"
        },
        "hook_intro_distinctness": {
          "$ref": "#/$defs/check_result"
        },
        "narrative_spine": {
          "$ref": "#/$defs/check_result"
        },
        "specificity": {
          "$ref": "#/$defs/check_result"
        },
        "repetition_risk": {
          "$ref": "#/$defs/check_result"
        },
        "seo_alignment": {
          "$ref": "#/$defs/check_result"
        },
        "title_quality": {
          "$ref": "#/$defs/check_result"
        },
        "title_thumbnail_synergy": {
          "$ref": "#/$defs/check_result"
        },
        "description_quality": {
          "$ref": "#/$defs/check_result"
        },
        "tags_quality": {
          "$ref": "#/$defs/check_result"
        },
        "thumbnail_text_quality": {
          "$ref": "#/$defs/check_result"
        },
        "hiddenova_brand_intro": {
          "$ref": "#/$defs/check_result"
        },
        "standard_cta": {
          "$ref": "#/$defs/check_result"
        }
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendation"
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "source_agents",
        "next_agent"
      ],
      "properties": {
        "source_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_agent": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "video_id": {
      "type": "string",
      "pattern": "^video_[0-9]{3,}$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "check_result": {
      "type": "object",
      "required": [
        "status",
        "score"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warning",
            "fail"
          ]
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": [
        "field",
        "severity",
        "message"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "required": [
        "field",
        "suggestion"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "suggestion": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
