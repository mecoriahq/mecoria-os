{
  "type": "object",
  "required": [
    "agent",
    "version",
    "channel",
    "status",
    "overall_score",
    "summary",
    "asset_checks",
    "issues",
    "recommendations",
    "source",
    "metadata"
  ],
  "properties": {
    "agent": {
      "type": "string",
      "const": "internal_visual_render_qa"
    },
    "version": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "overall_score": {
      "type": "integer"
    },
    "summary": {
      "type": "object",
      "required": [
        "expected_assets",
        "approved_assets",
        "total_files",
        "valid_files",
        "next_agent"
      ],
      "properties": {
        "expected_assets": {
          "type": "integer"
        },
        "approved_assets": {
          "type": "integer"
        },
        "total_files": {
          "type": "integer"
        },
        "valid_files": {
          "type": "integer"
        },
        "next_agent": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "asset_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "asset_type",
          "render_status",
          "expected_files",
          "valid_files",
          "status",
          "file_checks"
        ],
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "asset_type": {
            "type": "string"
          },
          "render_status": {
            "type": "string"
          },
          "expected_files": {
            "type": "integer"
          },
          "valid_files": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          },
          "file_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "filename",
                "relative_path",
                "file_exists",
                "file_readable",
                "pillow_readable",
                "format_valid",
                "suffix_valid",
                "declared_format_valid",
                "size_bytes",
                "size_valid",
                "resolution",
                "expected_resolution",
                "resolution_valid",
                "status",
                "score"
              ],
              "properties": {
                "filename": {
                  "type": "string"
                },
                "relative_path": {
                  "type": "string"
                },
                "file_exists": {
                  "type": "boolean"
                },
                "file_readable": {
                  "type": "boolean"
                },
                "pillow_readable": {
                  "type": "boolean"
                },
                "format_valid": {
                  "type": "boolean"
                },
                "suffix_valid": {
                  "type": "boolean"
                },
                "declared_format_valid": {
                  "type": "boolean"
                },
                "size_bytes": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "size_valid": {
                  "type": "boolean"
                },
                "resolution": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "expected_resolution": {
                  "type": "string"
                },
                "resolution_valid": {
                  "type": "boolean"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail"
                  ]
                },
                "score": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "severity",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "suggestion"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "source": {
      "type": "object",
      "required": [
        "source_agents",
        "internal_visual_render_reference"
      ],
      "properties": {
        "source_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "internal_visual_render_reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": [
        "next_agent"
      ],
      "properties": {
        "next_agent": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
