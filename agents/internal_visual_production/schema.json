{
  "type": "object",
  "required": [
    "agent",
    "version",
    "channel",
    "status",
    "internal_visual_assets",
    "summary",
    "source",
    "metadata"
  ],
  "properties": {
    "agent": {
      "type": "string",
      "const": "internal_visual_production"
    },
    "version": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "internal_assets_ready",
        "blocked"
      ]
    },
    "internal_visual_assets": {
      "type": "object",
      "required": [
        "assets"
      ],
      "properties": {
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "asset_id",
              "asset_type",
              "production_method",
              "production_status",
              "output_folder",
              "output_files",
              "source_manifest_folder"
            ],
            "properties": {
              "asset_id": {
                "type": "string"
              },
              "asset_type": {
                "type": "string"
              },
              "production_method": {
                "type": "string"
              },
              "production_status": {
                "type": "string"
              },
              "output_folder": {
                "type": "string"
              },
              "output_files": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "filename",
                    "relative_path",
                    "format"
                  ],
                  "properties": {
                    "filename": {
                      "type": "string"
                    },
                    "relative_path": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "source_manifest_folder": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "target_asset_count",
        "ready_asset_count",
        "next_agent"
      ],
      "properties": {
        "target_asset_count": {
          "type": "integer"
        },
        "ready_asset_count": {
          "type": "integer"
        },
        "next_agent": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "source_agents",
        "visual_asset_acquisition_reference"
      ],
      "properties": {
        "source_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visual_asset_acquisition_reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": [
        "next_agent"
      ],
      "properties": {
        "next_agent": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
