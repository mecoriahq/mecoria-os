{
  "type": "object",
  "required": [
    "agent",
    "version",
    "channel",
    "status",
    "overall_score",
    "summary",
    "checks",
    "section_checks",
    "issues",
    "recommendations",
    "source",
    "metadata"
  ],
  "properties": {
    "agent": {
      "type": "string",
      "const": "audio_qa"
    },
    "version": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "overall_score": {
      "type": "integer"
    },
    "summary": {
      "type": "object",
      "required": [
        "expected_sections",
        "checked_sections",
        "valid_sections",
        "missing_sections",
        "audio_ready",
        "combined_audio_ready"
      ],
      "properties": {
        "expected_sections": {
          "type": "integer"
        },
        "checked_sections": {
          "type": "integer"
        },
        "valid_sections": {
          "type": "integer"
        },
        "missing_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "audio_ready": {
          "type": "boolean"
        },
        "combined_audio_ready": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "object",
      "required": [
        "voice_generation_status",
        "audio_metadata_ready",
        "audio_ready",
        "combined_audio_ready"
      ],
      "properties": {
        "voice_generation_status": {
          "type": "string"
        },
        "audio_metadata_ready": {
          "type": "boolean"
        },
        "audio_ready": {
          "type": "boolean"
        },
        "combined_audio_ready": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "section_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sequence",
          "title",
          "relative_path",
          "file_exists",
          "file_readable",
          "format_valid",
          "size_bytes",
          "size_valid",
          "status",
          "score"
        ],
        "properties": {
          "sequence": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "relative_path": {
            "type": "string"
          },
          "file_exists": {
            "type": "boolean"
          },
          "file_readable": {
            "type": "boolean"
          },
          "format_valid": {
            "type": "boolean"
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ]
          },
          "size_valid": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          },
          "score": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "severity",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "suggestion"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "source": {
      "type": "object",
      "required": [
        "source_agents",
        "voice_generation_reference"
      ],
      "properties": {
        "source_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "voice_generation_reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": [
        "next_agent"
      ],
      "properties": {
        "next_agent": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
