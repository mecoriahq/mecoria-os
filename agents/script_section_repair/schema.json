{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "agent": {
      "const": "script_section_repair"
    },
    "version": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "video_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "repair_ready"
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "target_locations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string"
          },
          "narration": {
            "type": "string",
            "minLength": 1
          },
          "claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "change_summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "location",
          "narration",
          "claim_ids",
          "change_summary"
        ],
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string"
    },
    "script_reference": {
      "type": "string"
    },
    "quality": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  },
  "required": [
    "agent",
    "version",
    "channel",
    "video_id",
    "run_id",
    "status",
    "attempt",
    "target_locations",
    "repairs",
    "summary",
    "script_reference",
    "quality",
    "metadata"
  ],
  "additionalProperties": false
}
