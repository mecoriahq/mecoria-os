{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "repairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string"
          },
          "narration": {
            "type": "string",
            "minLength": 1
          },
          "claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "change_summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "location",
          "narration",
          "claim_ids",
          "change_summary"
        ],
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "repairs",
    "summary"
  ],
  "additionalProperties": false
}
